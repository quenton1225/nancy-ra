*********** cookie: " + value);\n  \n  limit = limit ? limit:1;\n\n  if ( value && value[1] ) {\n    //AMCV cookie exists with value\n    if ( (/\\|/gi).test(value[1]) ) {\n    //AMCV cookie contains |\n//      console.log("]*********** found | in cookie: " + value[1]);\n      document.cookie = value[0] + "=" + (value[1].replace(/\\|/g,"%7C")) + cookieParams\n    }\n  } else {\n    //AMCV cookie does not exist\n//    console.log("]*********** found no cookie ");\n    var consent = document.querySelector("[aria-label=\'Cookie Consent Banner\']");\n    if ( consent && !(/--hidden/gi).test(consent.classList) ){\n    //Consent banner is active\n//      console.log("]*********** consent banner not hidden ");\n      var observer = new MutationObserver((mutations) => {\n        mutations.forEach((mutation) => {\n//      console.log("]*********** consent banner mutation: " + mutation.attributeName);\n          if ( mutation.attributeName == "class") {\n//      console.log("]*********** run Patch");\n            AMCV_patch();\n          }\n        });\n      })\n      observer.observe(consent, {\n        subtree: false,\n        childList: false,\n        attributeFilter: ["class"],\n        attributes: true\n      });\n    } else {\n    //Consent banner is not active, cookie is not set\n//      console.log("]*********** consent banner hidden, limit: " + limit);\n      limit++;\n      if( limit < 13 ) {\n//      console.log("]*********** loop, limit: " + limit);\n        clearTimeout(poll);\n        var poll = setTimeout(AMCV_patch,500,limit)\n      } else {\n//      console.log("]*********** loop, past limit: " + limit);\n        //Enable Analytics from sidebar\n        var sidebar = function(e) {\n//          console.log("]*********** click event");\n              var ele = e.target.closest("button");\n//          console.log(ele);\n              if ( ele && (/osano-cm-save/).test(ele.classList) ) {\n//          console.log("]*********** ele && button && class");\n                AMCV_patch();\n              }\n        }\n        document.addEventListener("mousedown",sidebar);\n      }\n    }\n  }\n})();\n\n//console.log("\u300c\u039b\u039e\u03a4\u300d| Global:: AMCV cookie");\n',language:"javascript"},timeout:2e3,delayNext:!0},{modulePath:"core/src/lib/actions/customCode.js",settings:{global:!0,source:'alloy("getIdentity").then(function(result) {\n  window.auet_ecid = result.identity.ECID;\n});',language:"javascript"},timeout:2e3,delayNext:!0},{modulePath:"core/src/lib/actions/customCode.js",settings:{source:'/*\n  Logic:\n    Initial, first time visit -\n      current_delay doesn\'t exist - previous_delay set to "Not Set"\n      page loads - current_delay is set to:\n        1. Data Layer exists - "On Load"\n        2. Data Layer does not exist but path is in active list - "On Active Paths"\n        3. Data Layer does not exist and path is not in active list - "##" seconds either of when DataLayer was created or time out of 10sec\n      Data Layer event is present for scenarios 1 & 2 - preloaders rule executes - v67 is pushed as "Not Set"\n    OR\n      Data Layer is not present, preloaders does not execute.\n    Next page loads -\n      current_delay exists as set by previous page\n      page loads - current_delay is set to:\n        1. Data Layer exists - "On Load"\n        2. Data Layer does not exist but path is in active list - "On Active Paths"\n        3. Data Layer does not exist and path is not in active list - "##" seconds either of when DataLayer was created or time out of 10sec\n      Data Layer event is present for scenarios 1 & 2 - preloaders rule executes - v67 is pushed as value set by scenario\n    OR\n      Data Layer is not present, preloaders does not execute.*\n\n*/\n\n//    console.log("\u300c\u039bu\u039e\u03a4\u300d: data layer check");\nlocalStorage.setItem("analytics_previous_delay", localStorage.getItem("analytics_current_delay") || "Not Set");\nlocalStorage.setItem("analytics_previous_url", localStorage.